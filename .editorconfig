root = true

[*.{md,mdx}]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = false

[*.{py,rs,go,js,ts,jsx,tsx,c,cpp,h,java,sh,json,yml,yaml}]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{png,jpg,jpeg,gif,zip}]
trim_trailing_whitespace = false

[Makefile]
indent_style = tabroot = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{md,bazel,bzl}]
indent_style = space
indent_size = 2

[*.go]
indent_style = tab

[*.rs]
indent_style = space
indent_size = 4
