# Set default behavior to automatically normalize line endings
* text=auto

# Force LF for common source files and scripts
*.sh    text eol=lf
*.py    text eol=lf
*.go    text eol=lf
*.rs    text eol=lf
*.c     text eol=lf
*.cpp   text eol=lf
*.h     text eol=lf
*.java  text eol=lf
*.js    text eol=lf
*.ts    text eol=lf
*.jsx   text eol=lf
*.tsx   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf

# Binary files
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.zip   binary